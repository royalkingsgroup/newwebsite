<style>
/* ── Design Tokens ── */
:root{
  --gold:#C9A84C;--gold-light:#E8C96A;--gold-dark:#96771E;
  --crimson:#9B1D20;--deep:#0A0A0F;--dark:#10101A;
  --mid:#1A1A28;--surface:#1F1F30;--text:#F0ECE0;--muted:#8A8070;
  --t:0.3s ease;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Raleway',sans-serif;background:var(--deep);color:var(--text);overflow-x:hidden;-webkit-font-smoothing:antialiased;padding-top:68px;}


/* ═══ UNIFIED NAV ═══ */
#mainNav{position:fixed;top:0;width:100%;z-index:1000;padding:0;height:68px;display:flex;align-items:center;justify-content:space-between;background:rgba(10,10,15,0.97);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid rgba(201,168,76,0.2);transition:all 0.3s ease;}
#mainNav.scrolled{background:rgba(10,10,15,0.99);box-shadow:0 2px 20px rgba(0,0,0,0.5);}
/* .nav-logo moved to NAV LOGO WITH BRAND TEXT section */
.nav-logo img{height:44px;width:auto;object-fit:contain;transition:height 0.3s;}
nav.scrolled .nav-logo img{height:36px;}
.nav-links{display:flex;align-items:center;gap:14px;flex:1;justify-content:flex-end;padding-left:16px;}
.nav-links a{font-family:'Cinzel',serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;font-weight:600;color:rgba(240,236,224,0.78);text-decoration:none;transition:color 0.3s;white-space:nowrap;position:relative;padding-bottom:3px;}
.nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--gold);transition:width 0.3s;}
.nav-links a:hover::after,.nav-links a.active::after{width:100%;}
.nav-links a:hover,.nav-links a.active{color:var(--gold);}
.nav-cta{padding:7px 18px!important;border:1px solid var(--gold)!important;color:var(--gold)!important;border-radius:2px!important;transition:all 0.3s!important;}
.nav-cta:hover{background:var(--gold)!important;color:var(--deep)!important;}
.nav-cta::after{display:none!important;}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none;z-index:1100;margin-left:12px;}
.hamburger span{display:block;width:22px;height:2px;background:var(--gold);transition:all 0.3s;}
.hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.hamburger.open span:nth-child(2){opacity:0;}
.hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.mobile-drawer{position:fixed;top:0;right:-100%;width:280px;height:100vh;background:rgba(10,10,15,0.99);border-left:1px solid rgba(201,168,76,0.2);z-index:1050;padding:80px 32px 40px;display:flex;flex-direction:column;gap:18px;transition:right 0.35s cubic-bezier(0.4,0,0.2,1);backdrop-filter:blur(16px);}
.mobile-drawer.open{right:0;}
.mobile-drawer a{font-family:'Cinzel',serif;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:rgba(240,236,224,0.8);text-decoration:none;padding:11px 0;border-bottom:1px solid rgba(201,168,76,0.1);transition:color 0.3s,padding-left 0.3s;}
.mobile-drawer a:hover,.mobile-drawer a.active{color:var(--gold);}
.mobile-drawer a:hover{padding-left:5px;}
.drawer-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:1040;display:none;cursor:pointer;}
.drawer-overlay.open{display:block;}
@media(max-width:1100px){.nav-links{gap:14px;}.nav-links a{font-size:10px;letter-spacing:1.5px;}}
@media(max-width:768px){nav{padding:0 16px;height:62px;}.nav-links{display:none;}.hamburger{display:flex;}}

/* ═══ HERO ═══ */
#hero{position:relative;height:100svh;min-height:640px;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.hero-bg{position:absolute;inset:0;z-index:0;background-image:url('https://assets.zyrosite.com/XSgOr7vEzx2UoRJ7/merlion-cinemagraph-960x540-mnlJlokxQeIMGzkK.gif');background-size:cover;background-position:center 30%;filter:brightness(0.78) saturate(0.78);}
.hero-bg::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(10,10,15,0.02) 15%,rgba(10,10,15,0.55) 100%);}
.hero-content{position:relative;z-index:2;text-align:center;display:flex;flex-direction:column;align-items:center;padding:88px 20px 0;margin-top:-100px;}
.hero-eyebrow{font-family:'Cinzel',serif;font-size:clamp(11px,1vw,15px);letter-spacing:5px;color:var(--gold);text-transform:uppercase;margin-bottom:28px;animation:fadeUp 1s 0.2s both;}
.hero-logo-wrap{position:relative;margin-bottom:20px;animation:fadeUp 1.1s 0.35s both;}
.hero-logo-wrap::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:520px;height:520px;border-radius:50%;border:1px solid rgba(201,168,76,0.16);animation:pulse-ring 3.5s ease-out infinite;pointer-events:none;}
.hero-logo-wrap::after{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:460px;height:460px;border-radius:50%;border:1px solid rgba(201,168,76,0.08);animation:pulse-ring 3.5s ease-out 1.2s infinite;pointer-events:none;}
@keyframes pulse-ring{0%{opacity:0.5;transform:translate(-50%,-50%) scale(1);}100%{opacity:0;transform:translate(-50%,-50%) scale(1.55);}}
.hero-logo{width:clamp(280px,22vw,500px);max-width:75vw;height:auto;object-fit:contain;filter:drop-shadow(0 0 20px rgba(201,168,76,.15));image-rendering:auto;}
.hero-title{font-family:'Cinzel',serif;font-size:clamp(30px,4.2vw,80px);font-weight:700;letter-spacing:5px;line-height:1.1;text-transform:uppercase;color:var(--text);margin-bottom:6px;animation:fadeUp 1s 0.6s both;}
.hero-title span{color:#fff;}
.hero-slogan{font-family:'Cinzel',serif;font-size:clamp(10px,1.1vw,16px);letter-spacing:7px;text-transform:uppercase;color:var(--gold-light);font-weight:600;margin-bottom:18px;animation:fadeUp 1s 0.8s both;}
.hero-divider{width:56px;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);margin:0 auto 12px;animation:fadeUp 1s 0.95s both;}
.hero-tagline{font-size:16px;color:rgba(240,236,224,0.65);font-weight:300;max-width:580px;line-height:1.88;animation:fadeUp 1s 1.1s both;}
.hero-cta-row{display:flex;gap:14px;margin-top:20px;animation:fadeUp 1s 1.25s both;flex-wrap:wrap;justify-content:center;}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
.scroll-indicator{position:absolute;bottom:20px;left:50%;transform:translateX(-50%);z-index:2;animation:fadeUp 1s 1.8s both;}
.scroll-dot{width:1px;height:36px;background:linear-gradient(to bottom,var(--gold),transparent);animation:scroll-pulse 2s ease-in-out infinite;}
@keyframes scroll-pulse{0%,100%{opacity:0.3;}50%{opacity:1;}}

/* BUTTONS */
.btn-primary{padding:12px 30px;background:var(--gold);color:var(--deep);font-family:'Cinzel',serif;font-size:9.5px;letter-spacing:3px;text-transform:uppercase;font-weight:700;border:none;cursor:pointer;text-decoration:none;transition:all var(--t);clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);display:inline-flex;align-items:center;}
.btn-primary:hover{background:var(--gold-light);transform:translateY(-2px);}
.btn-ghost{padding:12px 30px;background:transparent;color:var(--gold);font-family:'Cinzel',serif;font-size:9.5px;letter-spacing:3px;text-transform:uppercase;font-weight:700;border:1px solid rgba(201,168,76,0.5);cursor:pointer;text-decoration:none;transition:all var(--t);clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);display:inline-flex;align-items:center;}
.btn-ghost:hover{border-color:var(--gold);background:rgba(201,168,76,0.08);}

/* STATS */
.stats-bar{
  background:linear-gradient(to right,var(--deep),var(--mid),var(--deep));
  border-top:1px solid rgba(201,168,76,.2);
  border-bottom:1px solid rgba(201,168,76,.2);
  padding:22px 40px;
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:0;
  margin-top:20px;
}
.stat-item{
  text-align:center;
  padding:12px 16px;
  border-right:1px solid rgba(201,168,76,.14);
}
.stat-item:last-child{border-right:none;}
.stat-item:last-child{border-right:none;}
.stat-num{font-family:'Cinzel',serif;font-size:30px;color:var(--gold);display:block;line-height:1;}
.stat-lbl{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-top:5px;display:block;}

/* SHARED */
.section-eyebrow{font-family:'Cinzel',serif;font-size:8.5px;letter-spacing:5px;text-transform:uppercase;color:var(--gold);margin-bottom:14px;display:block;}
.section-title{font-family:'Cormorant Garamond',serif;font-size:clamp(26px,3.2vw,46px);font-weight:300;line-height:1.3;color:var(--text);margin-bottom:14px;}
.section-title em{font-style:italic;color:var(--gold);}
.gold-rule{width:52px;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);margin:14px auto 22px;}

/* INTRO */
.intro-section{padding:72px 60px 56px;max-width:900px;margin:0 auto;text-align:center;}
.intro-text{font-size:16px;line-height:2.05;color:rgba(240,236,224,0.65);font-weight:300;}

/* PILLARS */
.pillars-section{padding:50px 28px 84px;background:var(--dark);}
.pillars-header{text-align:center;margin-bottom:48px;}
.pillars-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:3px;max-width:1500px;margin:0 auto;}
.pillar-card{position:relative;overflow:hidden;height:500px;background-size:cover;background-position:center;}
.pillar-card.clickable{cursor:pointer;}
.pillar-card.no-click{cursor:default;}
.pillar-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform 0.6s cubic-bezier(0.4,0,0.2,1);filter:brightness(0.4) saturate(0.6);}
.pillar-card.clickable:hover .pillar-bg{transform:scale(1.07);filter:brightness(0.52) saturate(0.75);}
.pillar-accent{position:absolute;top:0;left:0;width:2px;height:100%;z-index:2;background:linear-gradient(to bottom,transparent,var(--gold) 40%,var(--gold-dark));transform:scaleY(0);transform-origin:top;transition:transform 0.45s;}
.pillar-card.clickable:hover .pillar-accent{transform:scaleY(1);}
.pillar-inner{position:absolute;inset:0;z-index:3;padding:32px 22px 28px;display:flex;flex-direction:column;justify-content:flex-end;background:linear-gradient(to top,rgba(10,10,15,0.97) 0%,rgba(10,10,15,0.18) 60%,transparent 100%);}
.pillar-number{font-family:'Cinzel',serif;font-size:9.5px;letter-spacing:4px;color:var(--gold);margin-bottom:9px;opacity:0.6;}
.pillar-icon{font-size:24px;margin-bottom:9px;display:block;}
.pillar-title{font-family:'Cinzel',serif;font-size:12.5px;letter-spacing:1px;font-weight:600;color:var(--text);line-height:1.35;margin-bottom:4px;text-transform:uppercase;}
.pillar-sub{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:10px;}
.pillar-desc{font-size:11.5px;line-height:1.75;color:rgba(240,236,224,0.5);font-weight:300;max-height:0;overflow:hidden;transition:max-height 0.5s,opacity 0.4s;opacity:0;}
.pillar-card.clickable:hover .pillar-desc{max-height:120px;opacity:1;margin-top:4px;}
.pillar-cta{
  display:inline-block;
  font-family:'Raleway','Nunito Sans',sans-serif;
  font-size:8px;font-weight:800;letter-spacing:2px;
  text-transform:uppercase;
  color:var(--gold);
  border:1px solid rgba(201,168,76,.55);
  border-radius:2px;
  padding:5px 12px;
  margin-top:8px;
  background:rgba(201,168,76,.04);
  cursor:pointer;
  transition:background .25s,color .25s;
}
.pillar-card:hover .pillar-cta{background:rgba(201,168,76,.15);color:#fff;}
.pillar-card.clickable:hover .pillar-cta{
  display:inline-block;
  font-family:'Raleway','Nunito Sans',sans-serif;
  font-size:8px;font-weight:800;letter-spacing:2px;
  text-transform:uppercase;
  color:var(--gold);
  border:1px solid rgba(201,168,76,.55);
  border-radius:2px;
  padding:5px 12px;
  margin-top:8px;
  background:rgba(201,168,76,.04);
  cursor:pointer;
  transition:background .25s,color .25s;
}
.pillar-card:hover .pillar-cta{background:rgba(201,168,76,.15);color:#fff;}
.pillar-cta::after{content:' →';}
/* Fintech pillar — clickable */

/* WHY US */
.why-outer{background:var(--mid);}
.why-section{display:grid;grid-template-columns:5fr 7fr;gap:0;align-items:stretch;min-height:480px;}
.why-text-body{font-size:16px;line-height:2;color:rgba(240,236,224,0.65);font-weight:300;margin-bottom:22px;}
.why-image-wrap{position:relative;overflow:hidden;order:1;height:100%;}
.why-image-wrap::before{content:'';position:absolute;top:-14px;left:-14px;width:100%;height:100%;border:1px solid rgba(201,168,76,0.2);z-index:-1;}
.why-list{list-style:none;margin-top:20px;}
.why-list li{display:flex;gap:14px;margin-bottom:20px;align-items:flex-start;}
.why-icon{width:32px;height:32px;flex-shrink:0;border:1px solid rgba(201,168,76,0.3);display:flex;align-items:center;justify-content:center;font-size:13px;}
.why-list h4{font-family:'Cinzel',serif;font-size:10.5px;letter-spacing:2px;text-transform:uppercase;color:var(--text);margin-bottom:3px;font-weight:700;}
.why-list p{font-size:13px;line-height:1.75;color:var(--muted);}

/* YOUTUBE — poster that opens YT in new tab (embed is disabled by video owner) */
.yt-poster{
  position:relative;width:100%;height:100%;min-height:480px;overflow:hidden;
  background:#000;border:none;display:block;cursor:pointer;
}
.yt-poster>img{width:100%;height:100%;object-fit:cover;filter:brightness(0.72) saturate(0.65);transition:filter 0.4s,transform 0.5s;display:block;pointer-events:none;}
.yt-poster:hover>img{filter:brightness(0.88) saturate(0.8);transform:scale(1.04);}
.yt-overlay{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;background:rgba(10,10,15,0.28);transition:background var(--t);pointer-events:none;z-index:1;}
.yt-poster:hover .yt-overlay{background:rgba(10,10,15,0.15);}
.yt-play-btn{width:80px;height:80px;border-radius:50%;background:rgba(10,10,15,0.65);border:2px solid rgba(201,168,76,0.5);display:flex;align-items:center;justify-content:center;transition:all var(--t);box-shadow:0 0 28px rgba(201,168,76,0.2);}
.yt-poster:hover .yt-play-btn{background:rgba(201,168,76,0.18);border-color:var(--gold);box-shadow:0 0 44px rgba(201,168,76,0.4);transform:scale(1.1);}
.yt-label{font-family:'Cinzel',serif;font-size:9.5px;letter-spacing:4px;text-transform:uppercase;color:rgba(240,236,224,0.85);}
.yt-sublabel{font-size:10px;color:var(--muted);letter-spacing:1px;}

/* TESTIMONIALS */
.testimonials-section{padding:84px 60px;background:var(--dark);}
.testimonials-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;max-width:1200px;margin:0 auto;}
.testi-card{background:var(--surface);border:1px solid rgba(201,168,76,0.12);padding:32px 28px;position:relative;transition:border-color var(--t),transform var(--t);}
.testi-card:hover{border-color:rgba(201,168,76,0.38);transform:translateY(-4px);}
.testi-card::before{content:'\201C';position:absolute;top:14px;left:20px;font-family:'Cormorant Garamond',serif;font-size:60px;color:var(--gold);opacity:0.2;line-height:1;}
.testi-stars{color:var(--gold);font-size:12px;letter-spacing:2px;margin-bottom:14px;}
.testi-text{font-family:'Cormorant Garamond',serif;font-size:15.5px;line-height:1.75;color:rgba(240,236,224,0.72);font-style:italic;margin-bottom:20px;}
.testi-rule{width:28px;height:1px;background:var(--gold);margin-bottom:12px;}
.testi-name{font-family:'Cinzel',serif;font-size:9.5px;letter-spacing:2.5px;text-transform:uppercase;color:var(--text);margin-bottom:3px;font-weight:700;}
.testi-role{font-size:11px;color:var(--muted);}

/* CTA BAND */
.cta-band{padding:84px 60px;text-align:center;background:linear-gradient(to bottom,var(--dark),var(--deep));}
.cta-band p{font-size:13.5px;color:var(--muted);max-width:500px;margin:0 auto 32px;line-height:1.85;}
.cta-details{display:flex;gap:36px;justify-content:center;align-items:center;margin-top:24px;flex-wrap:wrap;}
.cta-detail{display:flex;align-items:center;gap:10px;font-size:12px;color:var(--muted);}
.cta-detail strong{color:var(--text);font-weight:600;}

/* FOOTER */
footer{background:var(--deep);border-top:1px solid rgba(201,168,76,0.14);padding:56px 60px 30px;}


.footer-brand img{height:150px;width:auto;object-fit:contain;margin-bottom:16px;filter:drop-shadow(0 0 10px rgba(201,168,76,0.15));}
.footer-brand p{font-size:12px;line-height:1.85;color:var(--muted);}

.footer-col h5{font-family:'Cinzel',serif;font-size:8.5px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid rgba(201,168,76,0.1);font-weight:700;}
.footer-col a{display:block;font-size:12px;color:var(--muted);text-decoration:none;margin-bottom:8px;transition:color var(--t),padding-left var(--t);}
.footer-col a:hover{color:var(--text);padding-left:4px;}



/* MICROSITE */
.microsite-overlay{position:fixed;inset:0;z-index:9000;background:rgba(5,5,10,0);display:none;align-items:center;justify-content:center;transition:background 0.4s;}
.microsite-overlay.active{display:flex!important;background:rgba(5,5,10,0.93);backdrop-filter:blur(14px);}
.microsite-panel{position:relative;width:92vw;max-width:1060px;max-height:90vh;overflow-y:auto;background:var(--surface);border:1px solid rgba(201,168,76,0.2);box-shadow:0 40px 100px rgba(0,0,0,0.85);opacity:0;transform:translateY(28px) scale(0.98);transition:opacity 0.4s,transform 0.4s;}
.microsite-overlay.active .microsite-panel{opacity:1;transform:translateY(0) scale(1);}
.microsite-hero{position:relative;height:270px;overflow:hidden;}
.microsite-hero img{width:100%;height:100%;object-fit:cover;filter:brightness(0.48) saturate(0.65);}
.microsite-hero-content{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:32px 40px;background:linear-gradient(to top,rgba(10,10,15,0.78) 0%,transparent 55%);}
.microsite-tag{font-family:'Cinzel',serif;font-size:8.5px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;}
.microsite-title{font-family:'Cinzel',serif;font-size:clamp(18px,2.6vw,30px);font-weight:700;letter-spacing:2px;color:var(--text);text-transform:uppercase;}
