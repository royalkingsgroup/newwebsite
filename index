/* ══════════════════════════════════════════════════════
   GLOBAL DESIGN REFINEMENT — Better contrast, readability
   Lighter section backgrounds, improved visual hierarchy
   ══════════════════════════════════════════════════════ */

/* Refined color tokens — slightly lifted backgrounds */
:root {
  --deep:    #0D0D14;   /* was #0A0A0F — very slightly lighter */
  --dark:    #131320;   /* was #10101A */
  --mid:     #1C1C2C;   /* was #1A1A28 */
  --surface: #232336;   /* was #1F1F30 */
  --surface2:#282840;   /* new: card hover surface */
  --text:    #F2EEE2;   /* was #F0ECE0 — slightly brighter */
  --muted:   #9A9080;   /* was #8A8070 — more readable */
  --border:  rgba(201,168,76,.18);  /* consistent border */
}

/* Section alternation — break up monotone black */
.pillar-page-section.dark,
.dark-section,
.why-outer,
.stats-bar,
.stats-strip {
  background: linear-gradient(to bottom, var(--dark), var(--mid)) !important;
}

/* Card improvements — slightly lighter, better hover */
.award-card,
.csr-card,
.np-card,
.post-card,
.fb-post-card,
.pillar-card,
.tm-card {
  background: var(--surface) !important;
  border-color: var(--border) !important;
  transition: background .25s, border-color .25s, transform .25s, box-shadow .25s !important;
}
.award-card:hover,
.csr-card:hover,
.np-card:hover,
.post-card:hover,
.tm-card:hover {
  background: var(--surface2) !important;
  border-color: rgba(201,168,76,.38) !important;
}

/* Improve hero brightness across all pages */
.page-hero-bg {
  filter: brightness(0.78) saturate(.75) !important;
}
.hero-bg {
  filter: brightness(.36) saturate(.7) !important;
}

/* Better text contrast */
body { color: var(--text); }

/* Line height improvements for body text */
.body-text p, .award-desc, .csr-desc, .np-desc,
.tm-desc, p { line-height: 1.85 !important; }

/* Section padding consistency */
.pillar-page-section,
.section-pad { padding: 80px 60px !important; }
@media(max-width:768px) {
  .pillar-page-section,
  .section-pad { padding: 52px 18px !important; }
}

/* Better form inputs */
input, textarea, select {
  background: rgba(255,255,255,.05) !important;
  border: 1px solid var(--border) !important;
  color: var(--text) !important;
  border-radius: 3px !important;
}
input:focus, textarea:focus {
  border-color: rgba(201,168,76,.5) !important;
  outline: none !important;
  box-shadow: 0 0 0 2px rgba(201,168,76,.12) !important;
}

/* Skip navigation for accessibility */
.skip-nav {
  position: absolute;
  top: -100%;
  left: 8px;
  padding: 8px 16px;
  background: var(--gold);
  color: var(--deep);
  font-family: 'Raleway', sans-serif;
  font-weight: 700;
  font-size: 12px;
  z-index: 9999;
  border-radius: 0 0 4px 4px;
  text-decoration: none;
  transition: top .2s;
}
.skip-nav:focus { top: 0; }

/* Improved focus indicators */
a:focus-visible,
button:focus-visible,
[tabindex]:focus-visible {
  outline: 2px solid var(--gold) !important;
  outline-offset: 3px !important;
}

/* Smooth scrolling */
html { scroll-behavior: smooth; }

/* Facebook plugin alignment */
.nf-plugin-outer {
  margin: 0 auto !important;
}
.nf-iframe {
  display: block !important;
  margin: 0 auto !important;
  max-width: 100% !important;
}
.nf-section {
  padding: 48px 24px 72px !important;
}
.news-feed-section {
  padding: 48px 24px 72px !important;
}

/* Better CTA buttons */
.btn-primary, .btn-p {
  position: relative;
  overflow: hidden;
}
.btn-primary::after, .btn-p::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,.08);
  opacity: 0;
  transition: opacity .2s;
}
.btn-primary:hover::after, .btn-p:hover::after { opacity: 1; }

/* Image lazy load fade */
img[loading="lazy"] {
  transition: opacity .4s;
}
img.loaded { opacity: 1; }

/* Large screen improvements */
@media(min-width:1440px) {
  .container,
  .news-feed-section > *,
  .nf-section > * {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }
}

