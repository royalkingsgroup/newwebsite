/* ─── NEWS DROPDOWN ─── */
.nav-dropdown{position:relative;display:flex;align-items:center;}
.nav-dropdown-trigger{font-family:'Cinzel',serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;font-weight:700;color:rgba(240,236,224,.78);text-decoration:none;transition:color var(--t);white-space:nowrap;position:relative;padding-bottom:3px;cursor:default;display:flex;align-items:center;gap:4px;}
.nav-dropdown-trigger::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--gold);transition:width var(--t);}
.nav-dropdown-trigger:hover::after,.nav-dropdown-trigger.active::after{width:100%;}
.nav-dropdown-trigger:hover,.nav-dropdown-trigger.active{color:var(--gold);}
.dropdown-arrow{font-size:9px;transition:transform var(--t);}
.nav-dropdown:hover .dropdown-arrow{transform:rotate(180deg);}
.nav-dropdown-menu{position:absolute;top:calc(100% + 2px);right:-12px;min-width:200px;margin-top:0;background:rgba(10,10,15,.98);border:1px solid rgba(201,168,76,.22);border-radius:3px;padding:10px 0 6px;display:none;flex-direction:column;z-index:1100;box-shadow:0 14px 44px rgba(0,0,0,.75);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);animation:ddIn .2s ease;}
@keyframes ddIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
.nav-dropdown-menu::before{content:'';position:absolute;top:-10px;left:0;right:0;height:10px;background:transparent;}

.nav-dropdown:hover .nav-dropdown-menu,.nav-dropdown-menu:hover{display:flex;}
.nav-dropdown-menu a{font-family:'Cinzel',serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:700;color:rgba(240,236,224,.78);text-decoration:none;padding:11px 20px;display:flex;align-items:center;gap:10px;transition:color var(--t),background var(--t);white-space:nowrap;}
.nav-dropdown-menu a:hover{color:var(--gold);background:rgba(201,168,76,.08);}
.dd-icon{font-size:13px;}
/* Mobile news sub-menu */
.mob-news-group{display:flex;flex-direction:column;border-bottom:1px solid rgba(201,168,76,.1);padding-bottom:2px;}
.mob-news-label{font-family:'Cinzel',serif;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);padding:11px 0 6px;font-weight:700;cursor:default;}
.mob-sub-link{font-size:10px!important;letter-spacing:2px!important;padding:7px 0 7px 16px!important;border-bottom:none!important;color:rgba(240,236,224,.7)!important;display:block;}
.mob-sub-link.active{color:var(--gold)!important;}
.mob-sub-link:hover{color:var(--gold)!important;padding-left:20px!important;}

/* Nav spacing adjustments */
@media(max-width:1200px){.nav-links{gap:12px;padding-left:12px;}}
@media(max-width:1000px){.nav-links{gap:11px;padding-left:12px;}}

#aboutDropdown .nav-dropdown-menu{right:auto;left:0;}

#newsDropdown .nav-dropdown-menu{right:auto;left:0;}
/* Mobile nav consistency fix */
.mob-about-label,.mob-news-label{font-family:'Cinzel',serif;font-size:10px !important;letter-spacing:2.5px !important;text-transform:uppercase;color:var(--gold);padding:10px 0 5px;font-weight:700;display:block;}
