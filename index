/* ── Open / close microsite ── */
function openMicrosite(k){
  var d=msData[k]; if(!d) return;
  document.getElementById('ms-tag').textContent=d.tag;
  document.getElementById('ms-title').textContent=d.title;
  document.getElementById('ms-img').src=d.img;
  document.getElementById('ms-img').alt=d.title;
  document.getElementById('ms-about').innerHTML=d.about;
  document.getElementById('ms-services').innerHTML=d.services.map(function(s){return'<li>'+s+'</li>';}).join('');
  var ov=document.getElementById('micrositeOverlay');
  ov.style.cssText='display:flex!important;';
  requestAnimationFrame(function(){requestAnimationFrame(function(){ov.classList.add('active');});});
  document.body.style.overflow='hidden';
  setTimeout(function(){var c=document.getElementById('msClose');if(c)c.focus();},420);
}
function closeMicrosite(){
  var ov=document.getElementById('micrositeOverlay');
  ov.classList.remove('active');
  setTimeout(function(){ov.style.display='none';},420);
  document.body.style.overflow='';
}
document.getElementById('micrositeOverlay').addEventListener('click',function(e){if(e.target===this)closeMicrosite();});
document.getElementById('msClose').addEventListener('click',closeMicrosite);
document.addEventListener('keydown',function(e){if(e.key==='Escape')closeMicrosite();});
document.querySelectorAll('.pillar-card.clickable').forEach(function(c){
  c.addEventListener('keydown',function(e){if(e.key==='Enter'||e.key===' '){e.preventDefault();c.click();}});
});

/* ── Hamburger / mobile drawer ── */

function openDrawer(){var d=document.getElementById('mobileDrawer'),o=document.getElementById('drawerOverlay'),h=document.getElementById('hamburger');if(!d)return;d.classList.add('open');d.setAttribute('aria-hidden','false');o.classList.add('open');h.classList.add('open');h.setAttribute('aria-expanded','true');document.body.style.overflow='hidden';}
function closeDrawer(){var d=document.getElementById('mobileDrawer'),o=document.getElementById('drawerOverlay'),h=document.getElementById('hamburger');if(!d)return;d.classList.remove('open');d.setAttribute('aria-hidden','true');o.classList.remove('open');h.classList.remove('open');h.setAttribute('aria-expanded','false');document.body.style.overflow='';}
(function(){var h=document.getElementById('hamburger');if(h){h.addEventListener('click',function(){this.classList.contains('open')?closeDrawer():openDrawer();});}var o=document.getElementById('drawerOverlay');if(o){o.addEventListener('click',closeDrawer);}window.addEventListener('scroll',function(){var n=document.getElementById('mainNav');if(n)n.classList.toggle('scrolled',window.scrollY>60);},{passive:true});})();

function playHomeVid(el){
  var iframe=document.createElement('iframe');
  iframe.src='https://www.youtube-nocookie.com/embed/5_vA68HdMMk?autoplay=1&rel=0&modestbranding=1';
  iframe.allow='autoplay;encrypted-media;picture-in-picture;fullscreen';
  iframe.setAttribute('allowfullscreen','');
  iframe.style.cssText='position:absolute;top:0;left:0;width:100%;height:100%;border:none;z-index:10;display:block;';
  el.style.position='relative';
  while(el.firstChild)el.removeChild(el.firstChild);
  el.appendChild(iframe);
  el.onclick=null;el.style.cursor='default';
}

/* Touch dropdown support */
(function(){
  ['newsDropdown','aboutDropdown'].forEach(function(did){
    var dd=document.getElementById(did);
  if(dd){
    dd.addEventListener('touchstart',function(e){
      var menu=dd.querySelector('.nav-dropdown-menu');
      menu.style.display=menu.style.display==='flex'?'':'flex';
      e.stopPropagation();
    },{passive:true});
    document.addEventListener('touchstart',function(e){
      if(!dd.contains(e.target)){var m=dd.querySelector('.nav-dropdown-menu');if(m)m.style.display='';}
    },{passive:true});
  }
  });
})();
