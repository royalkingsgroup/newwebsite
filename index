/* ═══ FONT ACCESSIBILITY IMPROVEMENT ═══ */
/* Replace thin Cinzel with bold Raleway for all UI labels/nav */
/* Raleway 700+ is thick, modern, highly readable at all ages  */

:root {
  --font-ui:   'Raleway', 'Nunito Sans', 'Inter', sans-serif;
  --font-body: 'Nunito Sans', 'Inter', sans-serif;
  --font-display: 'Cormorant Garamond', serif;
}

/* Override Cinzel across the board */
.nav-links a,
.nav-dropdown-trigger,
.nav-dropdown-menu a,
.nav-brand-text,
.mob-about-label,
.mob-news-label,
.mob-sub-link,
.mobile-drawer a {
  font-family: var(--font-ui) !important;
  font-weight: 700 !important;
  letter-spacing: 1.2px !important;
}

/* Nav top level: slightly larger + bold */
.nav-links a,
.nav-dropdown-trigger {
  font-size: 12px !important;
  letter-spacing: 1.5px !important;
  font-weight: 700 !important;
}

/* Dropdown menu items */
.nav-dropdown-menu a {
  font-size: 11.5px !important;
  letter-spacing: 1px !important;
  font-weight: 600 !important;
  text-transform: none !important;
}

/* Brand name */
.nav-brand-text {
  font-size: 14px !important;
  font-weight: 800 !important;
  letter-spacing: 2px !important;
}

/* Mobile drawer */
.mobile-drawer a {
  font-size: 13px !important;
  letter-spacing: 1.5px !important;
  font-weight: 700 !important;
}
.mob-sub-link {
  font-size: 12px !important;
  letter-spacing: 1px !important;
  font-weight: 600 !important;
  text-transform: none !important;
  color: rgba(240,236,224,.8) !important;
}
.mob-about-label,
.mob-news-label {
  font-size: 13px !important;
  letter-spacing: 1.5px !important;
}

/* Buttons */
.btn-primary, .btn-ghost,
.nav-cta, .btn-p, .btn-g,
.csr-btn, .np-view-btn,
.fb-page-btn, .fb-page-btn-ghost,
.nf-btn-solid, .nf-btn-outline,
.vm-btn, .retry-btn {
  font-family: var(--font-ui) !important;
  font-weight: 700 !important;
  letter-spacing: 1.2px !important;
